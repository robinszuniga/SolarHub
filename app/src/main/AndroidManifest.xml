<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION"/>
    <uses-permission android:name="android.permission.CAMERA"/>
    <uses-permission android:name="android.permission.USE_BIOMETRIC"/>

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.SolarHub">

        <!-- Splash Screen -->
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <!-- Transversal -->
        <activity android:name=".LoginActivity"/>
        <activity android:name=".RecuperarContrasenaActivity"/>
        <activity android:name=".GeolocalizacionActivity"/>

        <!-- Comprador -->
        <activity android:name=".InicioCompradorActivity"/>
        <activity android:name=".CatalogoActivity"/>
        <activity android:name=".DetalleProductoActivity"/>
        <activity android:name=".CarritoActivity"/>
        <activity android:name=".PasarelaPageosActivity"/>
        <activity android:name=".PerfilCompradorActivity"/>

        <!-- Administrador -->
        <activity android:name=".DashboardAdminActivity"/>
        <activity android:name=".GestionUsuariosActivity"/>
        <activity android:name=".CrearUsuarioActivity"/>
        <activity android:name=".EditarUsuarioActivity"/>
        <activity android:name=".GestionProductosActivity"/>
        <activity android:name=".ReportesActivity"/>

        <!-- Vendedor -->
        <activity android:name=".PanelVendedorActivity"/>
        <activity android:name=".CrearProductoActivity"/>
        <activity android:name=".HistorialPedidosActivity"/>
        <activity android:name=".PerfilVendedorActivity"/>

    </application>

</manifest>