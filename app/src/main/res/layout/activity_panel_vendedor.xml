<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo_claro">

    <!-- Toolbar -->
    <LinearLayout
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/verde_acento"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="☀ Mi Tienda"
            android:textColor="@color/texto_blanco"
            android:textSize="18sp"
            android:textStyle="bold"/>

        <Button
            android:id="@+id/btn_agregar"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="+ Agregar"
            android:backgroundTint="@color/azul_primario"
            android:textColor="@color/texto_blanco"
            android:textSize="12sp"/>

    </LinearLayout>

    <!-- Stats vendedor -->
    <LinearLayout
        android:id="@+id/layout_stats"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:background="@color/fondo_tarjeta"
        android:orientation="horizontal"
        android:elevation="4dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="4"
                android:textColor="@color/azul_primario"
                android:textSize="20sp"
                android:textStyle="bold"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Productos"
                android:textColor="@color/texto_secundario"
                android:textSize="10sp"/>
        </LinearLayout>

        <View android:layout_width="1dp" android:layout_height="match_parent"
            android:background="@color/fondo_gris"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$2.8M"
                android:textColor="@color/verde_acento"
                android:textSize="20sp"
                android:textStyle="bold"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ventas"
                android:textColor="@color/texto_secundario"
                android:textSize="10sp"/>
        </LinearLayout>

        <View android:layout_width="1dp" android:layout_height="match_parent"
            android:background="@color/fondo_gris"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⭐ 4.8"
                android:textColor="@color/naranja_acento"
                android:textSize="18sp"
                android:textStyle="bold"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Calificación"
                android:textColor="@color/texto_secundario"
                android:textSize="10sp"/>
        </LinearLayout>

        <View android:layout_width="1dp" android:layout_height="match_parent"
            android:background="@color/fondo_gris"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="12"
                android:textColor="@color/azul_medio"
                android:textSize="20sp"
                android:textStyle="bold"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pedidos"
                android:textColor="@color/texto_secundario"
                android:textSize="10sp"/>
        </LinearLayout>

    </LinearLayout>

    <!-- Título -->
    <TextView
        android:id="@+id/txt_titulo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Mis Productos"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="@color/texto_principal"
        android:layout_marginTop="12dp"
        android:layout_marginStart="16dp"
        app:layout_constraintTop_toBottomOf="@id/layout_stats"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Lista de productos con botones editar y eliminar -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/txt_titulo"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- Producto 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/fondo_tarjeta"
                android:orientation="vertical"
                android:padding="12dp"
                android:layout_marginBottom="8dp"
                android:elevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <!-- Imagen del producto -->
                    <View
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:background="@color/azul_claro"
                        android:layout_marginEnd="10dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Panel Solar 400W Monocristalino"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/texto_principal"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="$850.000"
                            android:textSize="13sp"
                            android:textColor="@color/verde_acento"
                            android:textStyle="bold"
                            android:layout_marginTop="2dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Stock: 15 unidades"
                            android:textSize="11sp"
                            android:textColor="@color/texto_secundario"/>
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp">
                    <Button
                        android:id="@+id/btn_editar_producto1"
                        android:layout_width="0dp"
                        android:layout_height="32dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        android:text="Editar"
                        android:textSize="11sp"
                        android:backgroundTint="@color/azul_primario"
                        android:textColor="@color/texto_blanco"/>
                    <Button
                        android:id="@+id/btn_eliminar_producto1"
                        android:layout_width="0dp"
                        android:layout_height="32dp"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        android:text="Eliminar"
                        android:textSize="11sp"
                        android:backgroundTint="@color/error"
                        android:textColor="@color/texto_blanco"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Producto 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/fondo_tarjeta"
                android:orientation="vertical"
                android:padding="12dp"
                android:layout_marginBottom="8dp"
                android:elevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <View
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:background="@color/verde_acento"
                        android:layout_marginEnd="10dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Batería Litio 200Ah 48V"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/texto_principal"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="$3.200.000"
                            android:textSize="13sp"
                            android:textColor="@color/verde_acento"
                            android:textStyle="bold"
                            android:layout_marginTop="2dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Stock: 5 unidades"
                            android:textSize="11sp"
                            android:textColor="@color/texto_secundario"/>
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp">
                    <Button
                        android:id="@+id/btn_editar_producto2"
                        android:layout_width="0dp"
                        android:layout_height="32dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        android:text="Editar"
                        android:textSize="11sp"
                        android:backgroundTint="@color/azul_primario"
                        android:textColor="@color/texto_blanco"/>
                    <Button
                        android:id="@+id/btn_eliminar_producto2"
                        android:layout_width="0dp"
                        android:layout_height="32dp"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        android:text="Eliminar"
                        android:textSize="11sp"
                        android:backgroundTint="@color/error"
                        android:textColor="@color/texto_blanco"/>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>