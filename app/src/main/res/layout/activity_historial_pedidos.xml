<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo_claro">

    <!-- Toolbar -->
    <LinearLayout
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/verde_acento"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="← Historial de Pedidos"
            android:textColor="@color/texto_blanco"
            android:textSize="17sp"
            android:textStyle="bold"/>

    </LinearLayout>

    <!-- Chips estado -->
    <HorizontalScrollView
        android:id="@+id/scroll_chips"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:paddingStart="12dp"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button android:layout_width="wrap_content" android:layout_height="30dp"
                android:text="Todos" android:textSize="11sp"
                android:backgroundTint="@color/verde_acento"
                android:textColor="@color/texto_blanco" android:layout_marginEnd="6dp"/>

            <Button android:layout_width="wrap_content" android:layout_height="30dp"
                android:text="Pendiente" android:textSize="11sp"
                android:backgroundTint="@color/naranja_acento"
                android:textColor="@color/texto_blanco" android:layout_marginEnd="6dp"/>

            <Button android:layout_width="wrap_content" android:layout_height="30dp"
                android:text="Pagado" android:textSize="11sp"
                android:backgroundTint="@color/fondo_gris"
                android:textColor="@color/texto_principal" android:layout_marginEnd="6dp"/>

            <Button android:layout_width="wrap_content" android:layout_height="30dp"
                android:text="Enviado" android:textSize="11sp"
                android:backgroundTint="@color/fondo_gris"
                android:textColor="@color/texto_principal" android:layout_marginEnd="6dp"/>

            <Button android:layout_width="wrap_content" android:layout_height="30dp"
                android:text="Entregado" android:textSize="11sp"
                android:backgroundTint="@color/fondo_gris"
                android:textColor="@color/texto_principal"/>

        </LinearLayout>
    </HorizontalScrollView>

    <!-- Lista pedidos -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_pedidos"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        app:layout_constraintTop_toBottomOf="@id/scroll_chips"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>