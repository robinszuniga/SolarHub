<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo_claro"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Toolbar -->
        <LinearLayout
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@color/azul_primario"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="← "
                android:textColor="@color/texto_blanco"
                android:textSize="18sp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pasarela de Pagos"
                android:textColor="@color/texto_blanco"
                android:textSize="18sp"
                android:textStyle="bold"/>

        </LinearLayout>

        <!-- Total a pagar -->
        <LinearLayout
            android:id="@+id/layout_total"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/azul_medio"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="20dp"
            android:paddingBottom="20dp"
            app:layout_constraintTop_toBottomOf="@id/toolbar">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Total a Pagar"
                android:textColor="@color/azul_claro"
                android:textSize="13sp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$2.439.500 COP"
                android:textColor="@color/texto_blanco"
                android:textSize="28sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp"/>

        </LinearLayout>

        <!-- Título método de pago -->
        <TextView
            android:id="@+id/txt_metodo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Selecciona método de pago"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/texto_principal"
            android:layout_marginTop="20dp"
            android:layout_marginStart="16dp"
            app:layout_constraintTop_toBottomOf="@id/layout_total"
            app:layout_constraintStart_toStartOf="parent"/>

        <!-- Tarjeta crédito/débito -->
        <LinearLayout
            android:id="@+id/layout_tarjeta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/fondo_tarjeta"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="16dp"
            android:layout_marginTop="12dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            app:layout_constraintTop_toBottomOf="@id/txt_metodo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💳  Tarjeta Crédito / Débito"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/texto_principal"
                android:layout_marginBottom="12dp"/>

            <EditText
                android:id="@+id/et_numero_tarjeta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Número de tarjeta"
                android:inputType="number"
                android:background="@color/fondo_gris"
                android:padding="12dp"
                android:textSize="14sp"
                android:layout_marginBottom="10dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/et_vencimiento"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="MM/AA"
                    android:inputType="number"
                    android:background="@color/fondo_gris"
                    android:padding="12dp"
                    android:textSize="14sp"
                    android:layout_marginEnd="8dp"/>

                <EditText
                    android:id="@+id/et_cvv"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="CVV"
                    android:inputType="numberPassword"
                    android:background="@color/fondo_gris"
                    android:padding="12dp"
                    android:textSize="14sp"/>

            </LinearLayout>

        </LinearLayout>

        <!-- PSE -->
        <LinearLayout
            android:id="@+id/layout_pse"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@color/fondo_tarjeta"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginTop="10dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            app:layout_constraintTop_toBottomOf="@id/layout_tarjeta"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🏦  Pagar con PSE"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/texto_principal"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="›"
                android:textSize="20sp"
                android:textColor="@color/texto_secundario"/>

        </LinearLayout>

        <!-- Seguridad -->
        <TextView
            android:id="@+id/txt_seguridad"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔒  Pago seguro con cifrado TLS 1.2"
            android:textSize="11sp"
            android:textColor="@color/verde_acento"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/layout_pse"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Botón confirmar -->
        <Button
            android:id="@+id/btn_confirmar"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:text="👆  Confirmar con Huella"
            android:backgroundTint="@color/azul_primario"
            android:textColor="@color/texto_blanco"
            android:textStyle="bold"
            android:textSize="15sp"
            android:layout_marginTop="16dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="32dp"
            app:layout_constraintTop_toBottomOf="@id/txt_seguridad"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>