<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo_claro">

    <!-- Toolbar -->
    <LinearLayout
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/azul_primario"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="← "
            android:textColor="@color/texto_blanco"
            android:textSize="18sp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mi Carrito"
            android:textColor="@color/texto_blanco"
            android:textSize="18sp"
            android:textStyle="bold"/>

    </LinearLayout>

    <!-- Lista items carrito -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_carrito"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toTopOf="@id/layout_resumen"/>

    <!-- Resumen de pago -->
    <LinearLayout
        android:id="@+id/layout_resumen"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/fondo_tarjeta"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Subtotal -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="6dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/txt_subtotal"
                android:textSize="13sp"
                android:textColor="@color/texto_secundario"/>
            <TextView
                android:id="@+id/txt_subtotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$2.050.000"
                android:textSize="13sp"
                android:textColor="@color/texto_principal"/>
        </LinearLayout>

        <!-- IVA -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="6dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/txt_iva"
                android:textSize="13sp"
                android:textColor="@color/texto_secundario"/>
            <TextView
                android:id="@+id/txt_iva"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$389.500"
                android:textSize="13sp"
                android:textColor="@color/texto_principal"/>
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/fondo_gris"
            android:layout_marginBottom="8dp"/>

        <!-- Total -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/txt_total"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/texto_principal"/>
            <TextView
                android:id="@+id/txt_total"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$2.439.500"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/azul_primario"/>
        </LinearLayout>

        <!-- Botón pagar huella -->
        <Button
            android:id="@+id/btn_huella"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="@string/btn_pagar_huella"
            android:backgroundTint="@color/azul_primario"
            android:textColor="@color/texto_blanco"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <!-- Botón pagar tarjeta -->
        <Button
            android:id="@+id/btn_tarjeta"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="@string/btn_pagar_tarjeta"
            android:backgroundTint="@color/fondo_gris"
            android:textColor="@color/azul_primario"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>