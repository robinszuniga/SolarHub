<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo_claro"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Toolbar -->
        <LinearLayout
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@color/azul_primario"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="← Editar Usuario"
                android:textColor="@color/texto_blanco"
                android:textSize="17sp"
                android:textStyle="bold"/>

        </LinearLayout>

        <!-- Foto -->
        <LinearLayout
            android:id="@+id/layout_foto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="20dp"
            android:paddingBottom="16dp"
            android:background="@color/fondo_tarjeta"
            app:layout_constraintTop_toBottomOf="@id/toolbar">

            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:background="@color/azul_medio"
                android:contentDescription="Foto usuario"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📷  Cambiar foto"
                android:textColor="@color/azul_medio"
                android:textSize="13sp"
                android:layout_marginTop="8dp"/>

        </LinearLayout>

        <!-- Formulario -->
        <LinearLayout
            android:id="@+id/layout_form"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/fondo_tarjeta"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="16dp"
            android:layout_marginTop="10dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            app:layout_constraintTop_toBottomOf="@id/layout_foto"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nombre completo"
                android:textSize="11sp"
                android:textColor="@color/texto_secundario"
                android:layout_marginBottom="4dp"/>

            <EditText
                android:id="@+id/et_nombre"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Nombre completo"
                android:text="Juan García"
                android:background="@color/fondo_gris"
                android:padding="12dp"
                android:textSize="14sp"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Correo electrónico"
                android:textSize="11sp"
                android:textColor="@color/texto_secundario"
                android:layout_marginBottom="4dp"/>

            <EditText
                android:id="@+id/et_correo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="correo@email.com"
                android:text="juan@email.com"
                android:inputType="textEmailAddress"
                android:background="@color/fondo_gris"
                android:padding="12dp"
                android:textSize="14sp"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Teléfono"
                android:textSize="11sp"
                android:textColor="@color/texto_secundario"
                android:layout_marginBottom="4dp"/>

            <EditText
                android:id="@+id/et_telefono"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="+57 300 000 0000"
                android:text="+57 310 555 1234"
                android:inputType="phone"
                android:background="@color/fondo_gris"
                android:padding="12dp"
                android:textSize="14sp"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rol"
                android:textSize="11sp"
                android:textColor="@color/texto_secundario"
                android:layout_marginBottom="4dp"/>

            <Spinner
                android:id="@+id/spinner_rol"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@color/fondo_gris"
                android:padding="12dp"/>

            <!-- Estado -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Estado"
                android:textSize="11sp"
                android:textColor="@color/texto_secundario"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="4dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_activo"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="Activo"
                    android:backgroundTint="@color/verde_acento"
                    android:textColor="@color/texto_blanco"
                    android:textSize="12sp"
                    android:layout_marginEnd="8dp"/>

                <Button
                    android:id="@+id/btn_suspender"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="Suspender"
                    android:backgroundTint="@color/error"
                    android:textColor="@color/texto_blanco"
                    android:textSize="12sp"/>

            </LinearLayout>

        </LinearLayout>

        <!-- Botones -->
        <Button
            android:id="@+id/btn_guardar"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:text="@string/btn_guardar"
            android:backgroundTint="@color/azul_primario"
            android:textColor="@color/texto_blanco"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            app:layout_constraintTop_toBottomOf="@id/layout_form"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <Button
            android:id="@+id/btn_eliminar"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:text="🗑  Eliminar Usuario"
            android:backgroundTint="@color/error"
            android:textColor="@color/texto_blanco"
            android:textStyle="bold"
            android:layout_marginTop="8dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="32dp"
            app:layout_constraintTop_toBottomOf="@id/btn_guardar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>