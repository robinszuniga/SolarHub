<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo_claro"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Toolbar -->
        <LinearLayout
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@color/azul_primario"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="← Reportes de Ventas"
                android:textColor="@color/texto_blanco"
                android:textSize="17sp"
                android:textStyle="bold"/>

        </LinearLayout>

        <!-- Resumen mes -->
        <LinearLayout
            android:id="@+id/layout_resumen"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/azul_medio"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="16dp"
            android:paddingBottom="16dp"
            app:layout_constraintTop_toBottomOf="@id/toolbar">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ventas del Mes"
                android:textColor="@color/azul_claro"
                android:textSize="13sp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$42.000.000 COP"
                android:textColor="@color/texto_blanco"
                android:textSize="26sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="↑ +8% vs mes anterior"
                android:textColor="@color/verde_claro"
                android:textSize="12sp"
                android:layout_marginTop="4dp"/>

        </LinearLayout>

        <!-- KPIs secundarios -->
        <LinearLayout
            android:id="@+id/layout_kpis"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            app:layout_constraintTop_toBottomOf="@id/layout_resumen">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="72dp"
                android:layout_weight="1"
                android:background="@color/fondo_tarjeta"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginEnd="6dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="156"
                    android:textColor="@color/azul_primario"
                    android:textSize="22sp"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pedidos"
                    android:textColor="@color/texto_secundario"
                    android:textSize="11sp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="72dp"
                android:layout_weight="1"
                android:background="@color/fondo_tarjeta"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginEnd="6dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$270k"
                    android:textColor="@color/verde_acento"
                    android:textSize="22sp"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Promedio"
                    android:textColor="@color/texto_secundario"
                    android:textSize="11sp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="72dp"
                android:layout_weight="1"
                android:background="@color/fondo_tarjeta"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="87"
                    android:textColor="@color/naranja_acento"
                    android:textSize="22sp"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Productos"
                    android:textColor="@color/texto_secundario"
                    android:textSize="11sp"/>
            </LinearLayout>

        </LinearLayout>

        <!-- Título top productos -->
        <TextView
            android:id="@+id/txt_top"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Top Productos del Mes"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/texto_principal"
            android:layout_marginTop="20dp"
            android:layout_marginStart="16dp"
            app:layout_constraintTop_toBottomOf="@id/layout_kpis"
            app:layout_constraintStart_toStartOf="parent"/>

        <!-- Lista top productos -->
        <LinearLayout
            android:id="@+id/layout_top"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/fondo_tarjeta"
            android:orientation="vertical"
            android:layout_marginTop="10dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            app:layout_constraintTop_toBottomOf="@id/txt_top"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:gravity="center_vertical"
                android:background="@color/fondo_gris">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="1. Panel Solar 400W Jinko"
                    android:textSize="13sp" android:textColor="@color/texto_principal"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="$12.5M" android:textSize="13sp"
                    android:textColor="@color/verde_acento" android:textStyle="bold"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/fondo_gris"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:gravity="center_vertical">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="2. Batería 200Ah Pylontech"
                    android:textSize="13sp" android:textColor="@color/texto_principal"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="$9.6M" android:textSize="13sp"
                    android:textColor="@color/verde_acento" android:textStyle="bold"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/fondo_gris"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:gravity="center_vertical"
                android:background="@color/fondo_gris">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="3. Inversor 3kW Growatt"
                    android:textSize="13sp" android:textColor="@color/texto_principal"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="$7.8M" android:textSize="13sp"
                    android:textColor="@color/verde_acento" android:textStyle="bold"/>
            </LinearLayout>

        </LinearLayout>

        <!-- Botón exportar -->
        <Button
            android:id="@+id/btn_exportar"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:text="📊  Exportar Reporte CSV"
            android:backgroundTint="@color/verde_acento"
            android:textColor="@color/texto_blanco"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="32dp"
            app:layout_constraintTop_toBottomOf="@id/layout_top"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>