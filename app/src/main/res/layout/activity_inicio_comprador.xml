<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo_claro"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Header -->
        <LinearLayout
            android:id="@+id/header"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:background="@color/azul_primario"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="☀ SolarHub"
                    android:textColor="@color/texto_blanco"
                    android:textSize="22sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bienvenido, Robinson"
                    android:textColor="@color/azul_claro"
                    android:textSize="13sp"
                    android:layout_marginTop="4dp"/>

            </LinearLayout>

            <ImageView
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@color/azul_medio"
                android:contentDescription="Foto perfil"/>

        </LinearLayout>

        <!-- Banner promocional -->
        <LinearLayout
            android:id="@+id/banner"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:background="@color/verde_acento"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            app:layout_constraintTop_toBottomOf="@id/header">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚡ Ahorra hasta 70% en tu factura"
                android:textColor="@color/texto_blanco"
                android:textSize="18sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Instala paneles solares con instaladores certificados RETIE"
                android:textColor="@color/texto_blanco"
                android:textSize="12sp"
                android:gravity="center"
                android:layout_marginTop="6dp"/>

            <Button
                android:id="@+id/btn_ver_productos"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Ver productos"
                android:backgroundTint="@color/texto_blanco"
                android:textColor="@color/verde_acento"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginTop="10dp"/>

        </LinearLayout>

        <!-- Categorías -->
        <TextView
            android:id="@+id/txt_categorias"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Categorías"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/texto_principal"
            android:layout_marginTop="16dp"
            android:layout_marginStart="16dp"
            app:layout_constraintTop_toBottomOf="@id/banner"
            app:layout_constraintStart_toStartOf="parent"/>

        <LinearLayout
            android:id="@+id/layout_categorias"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            app:layout_constraintTop_toBottomOf="@id/txt_categorias">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="72dp"
                android:layout_weight="1"
                android:background="@color/azul_primario"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginEnd="6dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="☀️" android:textSize="22sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Paneles" android:textColor="@color/texto_blanco" android:textSize="11sp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="72dp"
                android:layout_weight="1"
                android:background="@color/verde_acento"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginEnd="6dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="🔋" android:textSize="22sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Baterías" android:textColor="@color/texto_blanco" android:textSize="11sp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="72dp"
                android:layout_weight="1"
                android:background="@color/azul_medio"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginEnd="6dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="⚡" android:textSize="22sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Inversores" android:textColor="@color/texto_blanco" android:textSize="11sp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="72dp"
                android:layout_weight="1"
                android:background="@color/naranja_acento"
                android:orientation="vertical"
                android:gravity="center">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="🔧" android:textSize="22sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Servicios" android:textColor="@color/texto_blanco" android:textSize="11sp"/>
            </LinearLayout>

        </LinearLayout>

        <!-- Productos destacados -->
        <TextView
            android:id="@+id/txt_destacados"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Productos Destacados"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/texto_principal"
            android:layout_marginTop="20dp"
            android:layout_marginStart="16dp"
            app:layout_constraintTop_toBottomOf="@id/layout_categorias"
            app:layout_constraintStart_toStartOf="parent"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_destacados"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginTop="10dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            app:layout_constraintTop_toBottomOf="@id/txt_destacados"/>

        <!-- Instaladores cercanos -->
        <TextView
            android:id="@+id/txt_instaladores"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📍 Instaladores Cercanos"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/texto_principal"
            android:layout_marginTop="20dp"
            android:layout_marginStart="16dp"
            app:layout_constraintTop_toBottomOf="@id/rv_destacados"
            app:layout_constraintStart_toStartOf="parent"/>

        <LinearLayout
            android:id="@+id/layout_instaladores"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@color/fondo_tarjeta"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:gravity="center_vertical"
            android:layout_marginTop="10dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="80dp"
            app:layout_constraintTop_toBottomOf="@id/txt_instaladores"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Ver instaladores certificados RETIE cerca de ti"
                android:textSize="13sp"
                android:textColor="@color/texto_principal"/>

            <Button
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Ver mapa"
                android:backgroundTint="@color/azul_primario"
                android:textColor="@color/texto_blanco"
                android:textSize="11sp"/>

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>