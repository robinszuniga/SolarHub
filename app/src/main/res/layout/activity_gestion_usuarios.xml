<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo_claro">

    <!-- Toolbar -->
    <LinearLayout
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/azul_primario"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="← Gestión de Usuarios"
            android:textColor="@color/texto_blanco"
            android:textSize="17sp"
            android:textStyle="bold"/>

        <Button
            android:id="@+id/btn_crear"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="+ Crear"
            android:backgroundTint="@color/verde_acento"
            android:textColor="@color/texto_blanco"
            android:textSize="12sp"/>

    </LinearLayout>

    <!-- Barra búsqueda -->
    <EditText
        android:id="@+id/et_buscar"
        android:layout_width="0dp"
        android:layout_height="42dp"
        android:hint="🔍  Buscar usuario..."
        android:background="@color/fondo_tarjeta"
        android:padding="10dp"
        android:textSize="13sp"
        android:layout_marginTop="8dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Chips rol -->
    <HorizontalScrollView
        android:id="@+id/scroll_chips"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:paddingStart="12dp"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/et_buscar">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button android:layout_width="wrap_content" android:layout_height="30dp"
                android:text="Todos" android:textSize="11sp"
                android:backgroundTint="@color/azul_primario"
                android:textColor="@color/texto_blanco" android:layout_marginEnd="6dp"/>

            <Button android:layout_width="wrap_content" android:layout_height="30dp"
                android:text="Admin" android:textSize="11sp"
                android:backgroundTint="@color/fondo_gris"
                android:textColor="@color/texto_principal" android:layout_marginEnd="6dp"/>

            <Button android:layout_width="wrap_content" android:layout_height="30dp"
                android:text="Vendedor" android:textSize="11sp"
                android:backgroundTint="@color/fondo_gris"
                android:textColor="@color/texto_principal" android:layout_marginEnd="6dp"/>

            <Button android:layout_width="wrap_content" android:layout_height="30dp"
                android:text="Comprador" android:textSize="11sp"
                android:backgroundTint="@color/fondo_gris"
                android:textColor="@color/texto_principal"/>

        </LinearLayout>
    </HorizontalScrollView>

    <!-- Lista usuarios -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_usuarios"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        app:layout_constraintTop_toBottomOf="@id/scroll_chips"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>