<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo_claro">

    <!-- Toolbar -->
    <LinearLayout
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/azul_primario"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="12dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="☀ SolarHub"
            android:textColor="@color/texto_blanco"
            android:textSize="20sp"
            android:textStyle="bold"/>

        <!-- Barra de búsqueda -->
        <EditText
            android:id="@+id/et_buscar"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:layout_marginTop="10dp"
            android:background="@color/fondo_tarjeta"
            android:drawableStart="@android:drawable/ic_menu_search"
            android:hint="@string/hint_buscar"
            android:inputType="text"
            android:padding="10dp"
            android:textSize="13sp"/>

    </LinearLayout>

    <!-- Chips de filtros -->
    <HorizontalScrollView
        android:id="@+id/scroll_chips"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <Button
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="Todos"
                android:textSize="11sp"
                android:backgroundTint="@color/azul_primario"
                android:textColor="@color/texto_blanco"
                android:layout_marginEnd="6dp"/>

            <Button
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="Paneles"
                android:textSize="11sp"
                android:backgroundTint="@color/fondo_gris"
                android:textColor="@color/texto_principal"
                android:layout_marginEnd="6dp"/>

            <Button
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="Baterías"
                android:textSize="11sp"
                android:backgroundTint="@color/fondo_gris"
                android:textColor="@color/texto_principal"
                android:layout_marginEnd="6dp"/>

            <Button
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="Kits"
                android:textSize="11sp"
                android:backgroundTint="@color/fondo_gris"
                android:textColor="@color/texto_principal"
                android:layout_marginEnd="6dp"/>

            <Button
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="Servicios"
                android:textSize="11sp"
                android:backgroundTint="@color/fondo_gris"
                android:textColor="@color/texto_principal"/>

        </LinearLayout>
    </HorizontalScrollView>

    <!-- Lista de productos -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_productos"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        app:layout_constraintTop_toBottomOf="@id/scroll_chips"
        app:layout_constraintBottom_toTopOf="@id/bottom_navigation"/>

    <!-- Bottom Navigation real usando el componente de Material Design -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/fondo_tarjeta"
        android:elevation="8dp"
        app:itemIconTint="@color/azul_primario"
        app:itemTextColor="@color/azul_primario"
        app:menu="@menu/bottom_nav_menu"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>