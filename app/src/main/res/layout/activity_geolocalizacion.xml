<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo_claro">

    <!-- Toolbar -->
    <LinearLayout
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/azul_primario"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="← Instaladores Cercanos"
            android:textColor="@color/texto_blanco"
            android:textSize="17sp"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📍"
            android:textSize="20sp"/>

    </LinearLayout>

    <!-- Mapa placeholder -->
    <FrameLayout
        android:id="@+id/map_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@color/fondo_gris"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toTopOf="@id/txt_cercanos"
        app:layout_constraintHeight_percent="0.45">

        <!-- Simulación mapa -->
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/fondo_gris"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="🗺 Mapa de Instaladores\n(Google Maps API)"
            android:textSize="14sp"
            android:textColor="@color/texto_secundario"
            android:gravity="center"/>

        <!-- Mi ubicación -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="60dp"
            android:text="📍"
            android:textSize="30sp"/>

    </FrameLayout>

    <!-- Título lista -->
    <TextView
        android:id="@+id/txt_cercanos"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Instaladores Certificados RETIE"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="@color/texto_principal"
        android:layout_marginStart="16dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/map_container"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Lista instaladores -->
    <LinearLayout
        android:id="@+id/layout_instaladores"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:layout_marginTop="8dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintTop_toBottomOf="@id/txt_cercanos"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Instalador 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:background="@color/fondo_tarjeta"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">

            <TextView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@color/verde_acento"
                android:text="A"
                android:textColor="@color/texto_blanco"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SolarTech Barranquilla"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/texto_principal"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0.8 km  •  ⭐ 4.9  •  Cert. RETIE"
                    android:textSize="11sp"
                    android:textColor="@color/texto_secundario"/>
            </LinearLayout>

            <Button
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="Contactar"
                android:backgroundTint="@color/verde_acento"
                android:textColor="@color/texto_blanco"
                android:textSize="11sp"/>

        </LinearLayout>

        <!-- Instalador 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:background="@color/fondo_tarjeta"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">

            <TextView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@color/azul_medio"
                android:text="B"
                android:textColor="@color/texto_blanco"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Energía Solar Colombia"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/texto_principal"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1.4 km  •  ⭐ 4.7  •  Cert. RETIE"
                    android:textSize="11sp"
                    android:textColor="@color/texto_secundario"/>
            </LinearLayout>

            <Button
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="Contactar"
                android:backgroundTint="@color/azul_medio"
                android:textColor="@color/texto_blanco"
                android:textSize="11sp"/>

        </LinearLayout>

        <!-- Instalador 3 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:background="@color/fondo_tarjeta"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@color/naranja_acento"
                android:text="C"
                android:textColor="@color/texto_blanco"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="EcoSolar Ltda."
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/texto_principal"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2.1 km  •  ⭐ 4.6  •  Cert. RETIE"
                    android:textSize="11sp"
                    android:textColor="@color/texto_secundario"/>
            </LinearLayout>

            <Button
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="Contactar"
                android:backgroundTint="@color/naranja_acento"
                android:textColor="@color/texto_blanco"
                android:textSize="11sp"/>

        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>