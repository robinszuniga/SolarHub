<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo_claro"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Header verde vendedor -->
        <LinearLayout
            android:id="@+id/header"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:background="@color/verde_acento"
            android:orientation="vertical"
            android:gravity="center"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/img_perfil"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:background="@color/verde_claro"
                android:scaleType="centerCrop"
                android:contentDescription="Foto vendedor"/>

            <TextView
                android:id="@+id/txt_nombre"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SolarTech Colombia"
                android:textColor="@color/texto_blanco"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="10dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⭐ 4.8  •  Vendedor Certificado"
                android:textColor="@color/texto_blanco"
                android:textSize="13sp"
                android:layout_marginTop="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✅ Certificado RETIE"
                android:textColor="@color/texto_blanco"
                android:textSize="12sp"
                android:layout_marginTop="4dp"/>

        </LinearLayout>

        <!-- Botón editar -->
        <Button
            android:id="@+id/btn_editar"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:text="✏  Editar Perfil"
            android:backgroundTint="@color/fondo_tarjeta"
            android:textColor="@color/verde_acento"
            android:layout_marginTop="16dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            app:layout_constraintTop_toBottomOf="@id/header"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Info negocio -->
        <TextView
            android:id="@+id/txt_info_titulo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Información del Negocio"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/texto_principal"
            android:layout_marginTop="20dp"
            android:layout_marginStart="16dp"
            app:layout_constraintTop_toBottomOf="@id/btn_editar"
            app:layout_constraintStart_toStartOf="parent"/>

        <LinearLayout
            android:id="@+id/layout_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/fondo_tarjeta"
            android:orientation="vertical"
            android:layout_marginTop="10dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            app:layout_constraintTop_toBottomOf="@id/txt_info_titulo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:gravity="center_vertical">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="📧  Correo"
                    android:textSize="13sp" android:textColor="@color/texto_secundario"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="ventas@solartech.co"
                    android:textSize="13sp" android:textColor="@color/texto_principal"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/fondo_gris"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:gravity="center_vertical">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="📱  Teléfono"
                    android:textSize="13sp" android:textColor="@color/texto_secundario"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="+57 310 000 0000"
                    android:textSize="13sp" android:textColor="@color/texto_principal"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/fondo_gris"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:gravity="center_vertical">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="📍  Ciudad"
                    android:textSize="13sp" android:textColor="@color/texto_secundario"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Barranquilla, Colombia"
                    android:textSize="13sp" android:textColor="@color/texto_principal"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/fondo_gris"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:gravity="center_vertical">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="📋  RETIE"
                    android:textSize="13sp" android:textColor="@color/texto_secundario"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Cert. #12345 — Vigente"
                    android:textSize="13sp" android:textColor="@color/verde_acento"
                    android:textStyle="bold"/>
            </LinearLayout>

        </LinearLayout>

        <!-- Opciones -->
        <TextView
            android:id="@+id/txt_opciones"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Opciones"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/texto_principal"
            android:layout_marginTop="20dp"
            android:layout_marginStart="16dp"
            app:layout_constraintTop_toBottomOf="@id/layout_info"
            app:layout_constraintStart_toStartOf="parent"/>

        <LinearLayout
            android:id="@+id/layout_opciones"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/fondo_tarjeta"
            android:orientation="vertical"
            android:layout_marginTop="10dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="32dp"
            app:layout_constraintTop_toBottomOf="@id/txt_opciones"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:gravity="center_vertical">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="📊  Mis Reportes"
                    android:textSize="13sp" android:textColor="@color/texto_principal"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="›" android:textSize="20sp" android:textColor="@color/texto_secundario"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/fondo_gris"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:gravity="center_vertical">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="🔔  Notificaciones"
                    android:textSize="13sp" android:textColor="@color/texto_principal"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="›" android:textSize="20sp" android:textColor="@color/texto_secundario"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/fondo_gris"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:gravity="center_vertical">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="🚪  Cerrar Sesión"
                    android:textSize="13sp" android:textColor="@color/error"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="›" android:textSize="20sp" android:textColor="@color/texto_secundario"/>
            </LinearLayout>

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>