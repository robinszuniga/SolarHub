<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.SolarHub" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Color principal de la app -->
        <item name="colorPrimary">@color/azul_primario</item>
        <item name="colorPrimaryVariant">@color/azul_medio</item>
        <item name="colorOnPrimary">@color/texto_blanco</item>

        <!-- Color de acento -->
        <item name="colorSecondary">@color/verde_acento</item>
        <item name="colorSecondaryVariant">@color/verde_claro</item>
        <item name="colorOnSecondary">@color/texto_blanco</item>

        <!-- Fondo general -->
        <item name="android:colorBackground">@color/fondo_claro</item>
        <item name="colorSurface">@color/fondo_tarjeta</item>

        <!-- Barra de estado -->
        <item name="android:statusBarColor">@color/azul_primario</item>

        <!-- Sin ActionBar por defecto, usaremos Toolbar propia -->
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>
</resources>